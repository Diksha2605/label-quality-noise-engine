   "source": [
    "## 5. Save Reports"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create reports directory\n",
    "os.makedirs('../reports/phase4', exist_ok=True)\n",
    "os.makedirs('../reports/phase4/notebook_outputs', exist_ok=True)\n",
    "\n",
    "# Save comprehensive reports\n",
    "print(\"Saving reports...\")\n",
    "\n",
    "# Save quality reports\n",
    "for name, report in quality_reports.items():\n",
    "    # Remove large arrays for saving\n",
    "    clean_report = report.copy()\n",
    "    if 'component_details' in clean_report:\n",
    "        for component, details in clean_report['component_details'].items():\n",
    "            if 'label_agreements' in details:\n",
    "                del details['label_agreements']\n",
    "            if 'inconsistent_indices' in details:\n",
    "                del details['inconsistent_indices']\n",
    "    \n",
    "    report_file = f'../reports/phase4/notebook_outputs/{name}_quality_report.json'\n",
    "    with open(report_file, 'w') as f:\n",
    "        json.dump(clean_report, f, indent=2, default=str)\n",
    "    print(f\"  ✓ {name} quality report saved\")\n",
    "\n",
    "# Save comparison data\n",
    "if 'df_quality' in locals():\n",
    "    df_quality.to_csv('../reports/phase4/notebook_outputs/quality_comparison.csv', index=False)\n",
    "    print(f\"  ✓ Quality comparison saved\")\n",
    "\n",
    "# Generate summary\n",
    "summary = {\n",
    "    'phase': 4,\n",
    "    'datasets_analyzed': list(datasets.keys()),\n",
    "    'timestamp': pd.Timestamp.now().isoformat(),\n",
    "    'overall_quality_scores': {name: report['overall_score'] \n",
    "                              for name, report in quality_reports.items()}\n",
    "}\n",
    "\n",
    "with open('../reports/phase4/notebook_outputs/summary.json', 'w') as f:\n",
    "    json.dump(summary, f, indent=2)\n",
    "\n",
    "print(\"\\n✅ All reports saved to: reports/phase4/notebook_outputs/\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Key Insights and Recommendations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"🔍 KEY INSIGHTS FROM PHASE 4\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "if quality_reports:\n",
    "    # Find best and worst datasets\n",
    "    best_dataset = max(quality_reports.items(), key=lambda x: x[1]['overall_score'])\n",
    "    worst_dataset = min(quality_reports.items(), key=lambda x: x[1]['overall_score'])\n",
    "    \n",
    "    print(f\"\\n🏆 Best Dataset: {best_dataset[0]}\")\n",
    "    print(f\"   • Overall Score: {best_dataset[1]['overall_score']:.3f}\")\n",
    "    print(f\"   • Grade: {best_dataset[1]['quality_grade']}\")\n",
    "    \n",
    "    print(f\"\\n⚠️  Worst Dataset: {worst_dataset[0]}\")\n",
    "    print(f\"   • Overall Score: {worst_dataset[1]['overall_score']:.3f}\")\n",
    "    print(f\"   • Grade: {worst_dataset[1]['quality_grade']}\")\n",
    "    \n",
    "    # Common issues\n",
    "    print(f\"\\n📊 COMMON ISSUES IDENTIFIED:\")\n",
    "    all_issues = []\n",
    "    for name, report in quality_reports.items():\n",
    "        issues = report.get('component_details', {}).get('dataset_health', {}).get('issues', [])\n",
    "        all_issues.extend(issues)\n",
    "    \n",
    "    from collections import Counter\n",
    "    issue_counts = Counter(all_issues)\n",
    "    if issue_counts:\n",
    "        for issue, count in issue_counts.most_common(5):\n",
    "            print(f\"   • {issue}: {count} datasets\")\n",
    "    else:\n",
    "        print(\"   • No major issues detected across datasets\")\n",
    "    \n",
    "    # Top recommendations\n",
    "    print(f\"\\n💡 TOP RECOMMENDATIONS:\")\n",
    "    all_recommendations = []\n",
    "    for name, report in quality_reports.items():\n",
    "        recommendations = report.get('recommendations', [])\n",
    "        all_recommendations.extend([f\"{name}: {rec}\" for rec in recommendations])\n",
    "    \n",
    "    for i, rec in enumerate(all_recommendations[:5], 1):\n",
    "        print(f\"   {i}. {rec}\")\n",
    "else:\n",
    "    print(\"No quality reports generated.\")\n",
    "\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"✅ PHASE 4 COMPLETE!\")\n",

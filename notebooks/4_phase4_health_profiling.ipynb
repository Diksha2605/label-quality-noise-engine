 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Phase 4: Dataset Health Profiling\n",
    "\n",
    "**Goal**: Develop comprehensive metrics to assess dataset quality and label reliability.\n",
    "\n",
    "## What we'll do:\n",
    "1. **Health Metrics**: Calculate overall dataset health scores\n",
    "2. **Class Profiling**: Deep dive into individual class characteristics\n",
    "3. **Quality Scoring**: Unified scoring system for datasets and samples\n",
    "4. **Comparative Analysis**: Compare multiple datasets\n",
    "5. **Recommendations**: Generate actionable insights for improvement"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Import necessary libraries\n",
    "import sys\n",
    "import os\n",
    "sys.path.append('../src')\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import json\n",
    "\n",
    "from sklearn.datasets import load_digits, load_iris, make_classification\n",
    "\n",
    "# Set style\n",
    "sns.set_style(\"whitegrid\")\n",
    "plt.rcParams['figure.figsize'] = (12, 8)\n",
    "plt.rcParams['figure.dpi'] = 100\n",
    "\n",
    "print(\"✓ Libraries imported\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Datasets for Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load or create datasets for analysis\n",
    "print(\"Loading datasets...\")\n",
    "\n",
    "# Try to load from Phase 2\n",
    "phase2_dir = '../data/phase2_ready'\n",
    "\n",
    "datasets = {}\n",
    "\n",
    "if os.path.exists(phase2_dir):\n",
    "    import glob\n",
    "    csv_files = glob.glob(os.path.join(phase2_dir, \"*_cleaned.csv\"))\n",
    "    \n",
    "    if csv_files:\n",
    "        print(f\"Found {len(csv_files)} datasets from Phase 2:\")\n",
    "        for file in csv_files:\n",
    "            name = os.path.splitext(os.path.basename(file))[0].replace('_cleaned', '')\n",
    "            df = pd.read_csv(file)\n",
    "            \n",
    "            # Find target column\n",
    "            target_col = 'target'\n",
    "            for col in ['target', 'label', 'class', 'y']:\n",
    "                if col in df.columns:\n",
    "                    target_col = col\n",
    "                    break\n",
    "            \n",
    "            X = df.drop(columns=[target_col]).values\n",
    "            y = df[target_col].values\n",
    "            \n",
    "            datasets[name] = {'X': X, 'y': y, 'df': df}\n",
    "            print(f\"  • {name}: {X.shape[0]} samples, {X.shape[1]} features, {len(np.unique(y))} classes\")\n",
    "    else:\n",
    "        print(\"No Phase 2 datasets found. Creating sample datasets...\")\n",
    "else:\n",
    "    print(\"Phase 2 directory not found. Creating sample datasets...\")\n",
    "\n",
    "# Create sample datasets if none loaded\n",
    "if not datasets:\n",
    "    print(\"\\nCreating sample datasets...\")\n",
    "    \n",
    "    # Healthy dataset\n",
    "    X1, y1 = make_classification(\n",
    "        n_samples=500, n_features=20, n_classes=3,\n",
    "        n_informative=15, weights=[0.4, 0.35, 0.25], random_state=42\n",
    "    )\n",
    "    datasets['healthy_sample'] = {'X': X1, 'y': y1}\n",
    "    print(f\"  • healthy_sample: {X1.shape[0]} samples, {X1.shape[1]} features\")\n",
    "    \n",
    "    # Challenging dataset\n",
    "    X2, y2 = make_classification(\n",
    "        n_samples=300, n_features=30, n_classes=5,\n",
    "        n_informative=10, weights=[0.5, 0.2, 0.15, 0.1, 0.05],\n",
    "        flip_y=0.1, random_state=42\n",
    "    )\n",
    "    datasets['challenging_sample'] = {'X': X2, 'y': y2}\n",
    "    print(f\"  • challenging_sample: {X2.shape[0]} samples, {X2.shape[1]} features\")\n",
    "    \n",
    "    # Sklearn digits\n",
    "    digits = load_digits()\n",
    "    datasets['digits'] = {'X': digits.data, 'y': digits.target}\n",
    "    print(f\"  • digits: {digits.data.shape[0]} samples, {digits.data.shape[1]} features\")\n",
    "\n",
    "print(f\"\\n✓ Total datasets for analysis: {len(datasets)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Health Metrics Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from phase4_dataset_health.health_metrics import DatasetHealthMetrics\n",
    "\n",
    "# Initialize health metrics\n",
    "health_metrics = DatasetHealthMetrics()\n",
    "\n",
    "# Analyze each dataset\n",
    "health_reports = {}\n",
    "\n",
    "for name, data in datasets.items():\n",
    "    print(f\"\\n{'='*50}\")\n",
    "    print(f\"Health Analysis: {name}\")\n",
    "    print(f\"{'='*50}\")\n",
    "    \n",
    "    X = data['X']\n",
    "    y = data['y']\n",
    "    \n",
    "    # Generate health report\n",
    "    report = health_metrics.generate_health_report(X, y, name)\n",
    "    health_reports[name] = report\n",
    "    \n",
    "    # Extract key metrics for visualization\n",
    "    scores = report['component_scores']\n",
    "    print(f\"\\n  Component Scores:\")\n",
    "    for component, score in scores.items():\n",
    "        print(f\"    • {component.replace('_', ' ').title()}: {score:.3f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize health metrics comparison\n",
    "if len(health_reports) > 1:\n",
    "    print(\"\\n📊 Health Metrics Comparison\")\n",
    "    print(\"=\"*50)\n",
    "    \n",
    "    # Prepare data for visualization\n",
    "    comparison_data = []\n",
    "    for name, report in health_reports.items():\n",
    "        row = {'Dataset': name, 'Overall Health': report['overall_score']}\n",
    "        row.update(report['component_scores'])\n",
    "        comparison_data.append(row)\n",
    "    \n",
    "    df_comparison = pd.DataFrame(comparison_data)\n",
    "    \n",
    "    # Create radar chart\n",
    "    components = list(health_reports[list(health_reports.keys())[0]]['component_scores'].keys())\n",
    "    \n",
    "    fig, axes = plt.subplots(1, 2, figsize=(14, 6))\n",
    "    \n",
    "    # Bar chart\n",
    "    ax1 = axes[0]\n",
    "    x = np.arange(len(df_comparison))\n",
    "    width = 0.15\n",
    "    \n",
    "    for i, component in enumerate(components):\n",
    "        offset = (i - len(components)/2) * width + width/2\n",
    "        ax1.bar(x + offset, df_comparison[component], width, label=component.replace('_', ' ').title())\n",
    "    \n",
    "    ax1.set_xlabel('Dataset')\n",
    "    ax1.set_ylabel('Score')\n",
    "    ax1.set_title('Health Metrics by Dataset')\n",
    "    ax1.set_xticks(x)\n",
    "    ax1.set_xticklabels(df_comparison['Dataset'], rotation=45, ha='right')\n",
    "    ax1.legend(bbox_to_anchor=(1.05, 1), loc='upper left')\n",
    "    ax1.grid(True, alpha=0.3)\n",
    "    \n",
    "    # Overall health comparison\n",
    "    ax2 = axes[1]\n",
    "    datasets_sorted = df_comparison.sort_values('Overall Health', ascending=False)\n",
    "    bars = ax2.bar(range(len(datasets_sorted)), datasets_sorted['Overall Health'], \n",
    "                   color=sns.color_palette('viridis', len(datasets_sorted)))\n",
    "    \n",
    "    ax2.set_xlabel('Dataset')\n",
    "    ax2.set_ylabel('Overall Health Score')\n",
    "    ax2.set_title('Overall Dataset Health')\n",
    "    ax2.set_xticks(range(len(datasets_sorted)))\n",
    "    ax2.set_xticklabels(datasets_sorted['Dataset'], rotation=45, ha='right')\n",
    "    \n",
    "    # Add value labels\n",
    "    for bar, score in zip(bars, datasets_sorted['Overall Health']):\n",
    "        height = bar.get_height()\n",
    "        ax2.text(bar.get_x() + bar.get_width()/2., height + 0.01,\n",
    "                f'{score:.3f}', ha='center', va='bottom')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Class Profiling"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from phase4_dataset_health.class_profiling import ClassProfiler\n",
    "\n",
    "# Initialize class profiler\n",
    "profiler = ClassProfiler()\n",
    "\n",
    "# Profile classes for each dataset\n",
    "class_reports = {}\n",
    "\n",
    "for name, data in datasets.items():\n",
    "    print(f\"\\n{'='*50}\")\n",
    "    print(f\"Class Profiling: {name}\")\n",
    "    print(f\"{'='*50}\")\n",
    "    \n",
    "    X = data['X']\n",
    "    y = data['y']\n",
    "    \n",
    "    # Generate class report\n",
    "    report = profiler.generate_class_report(\n",
    "        X, y, name,\n",
    "        target_names=[f'Class {i}' for i in np.unique(y)]\n",
    "    )\n",
    "    class_reports[name] = report\n",
    "    \n",
    "    # Show problematic classes\n",
    "    problematic = report['problematic_classes']\n",
    "    if problematic:\n",
    "        print(f\"\\n  ⚠️  Problematic Classes ({len(problematic)}):\")\n",
    "        for i, cls in enumerate(problematic[:3], 1):  # Show top 3\n",
    "            print(f\"    {i}. Class {cls['class_label']} - {len(cls['issues'])} issues\")\n",
    "    else:\n",
    "        print(f\"\\n  ✅ No problematic classes found!\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize class characteristics\n",
    "if class_reports:\n",
    "    # Choose a dataset for detailed visualization\n",
    "    dataset_name = list(class_reports.keys())[0]\n",
    "    report = class_reports[dataset_name]\n",
    "    \n",
    "    # Extract class statistics\n",
    "    classes = []\n",
    "    n_samples = []\n",
    "    difficulty_scores = []\n",
    "    outlier_ratios = []\n",
    "    \n",
    "    for class_label, profile in report['class_profiles'].items():\n",
    "        classes.append(f\"Class {class_label}\")\n",
    "        n_samples.append(profile['n_samples'])\n",
    "        difficulty_scores.append(profile.get('difficulty_score', 0))\n",
    "        outlier_ratios.append(profile['outlier_analysis'].get('outlier_ratio', 0))\n",
    "    \n",
    "    # Create visualization\n",
    "    fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
    "    \n",
    "    # Class distribution\n",
    "    axes[0, 0].bar(classes, n_samples, color='skyblue')\n",
    "    axes[0, 0].set_title(f'Class Distribution - {dataset_name}')\n",
    "    axes[0, 0].set_xlabel('Class')\n",
    "    axes[0, 0].set_ylabel('Number of Samples')\n",
    "    axes[0, 0].tick_params(axis='x', rotation=45)\n",
    "    \n",
    "    # Difficulty scores\n",
    "    axes[0, 1].bar(classes, difficulty_scores, color='lightcoral')\n",
    "    axes[0, 1].axhline(0.7, color='red', linestyle='--', alpha=0.5, label='High Difficulty Threshold')\n",
    "    axes[0, 1].set_title(f'Class Difficulty Scores - {dataset_name}')\n",
    "    axes[0, 1].set_xlabel('Class')\n",
    "    axes[0, 1].set_ylabel('Difficulty Score (0-1)')\n",
    "    axes[0, 1].tick_params(axis='x', rotation=45)\n",
    "    axes[0, 1].legend()\n",
    "    \n",
    "    # Outlier ratios\n",
    "    axes[1, 0].bar(classes, outlier_ratios, color='lightgreen')\n",
    "    axes[1, 0].axhline(0.1, color='red', linestyle='--', alpha=0.5, label='High Outlier Threshold')\n",
    "    axes[1, 0].set_title(f'Class Outlier Ratios - {dataset_name}')\n",
    "    axes[1, 0].set_xlabel('Class')\n",
    "    axes[1, 0].set_ylabel('Outlier Ratio')\n",
    "    axes[1, 0].tick_params(axis='x', rotation=45)\n",
    "    axes[1, 0].legend()\n",
    "    \n",
    "    # Scatter plot: Difficulty vs Samples\n",
    "    scatter = axes[1, 1].scatter(n_samples, difficulty_scores, \n",
    "                                c=outlier_ratios, s=200, alpha=0.6,\n",
    "                                edgecolors='black', cmap='YlOrRd')\n",
    "    axes[1, 1].set_title(f'Class Analysis: Size vs Difficulty - {dataset_name}')\n",
    "    axes[1, 1].set_xlabel('Number of Samples')\n",
    "    axes[1, 1].set_ylabel('Difficulty Score')\n",
    "    \n",
    "    # Add class labels to points\n",
    "    for i, cls in enumerate(classes):\n",
    "        axes[1, 1].text(n_samples[i], difficulty_scores[i], cls, \n",
    "                       fontsize=9, ha='center', va='center')\n",
    "    \n",
    "    plt.colorbar(scatter, ax=axes[1, 1], label='Outlier Ratio')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Quality Scoring"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from phase4_dataset_health.quality_scoring import QualityScorer\n",
    "\n",
    "# Initialize quality scorer\n",
    "scorer = QualityScorer()\n",
    "\n",
    "# Score each dataset\n",
    "quality_reports = {}\n",
    "\n",
    "for name, data in datasets.items():\n",
    "    print(f\"\\n{'='*50}\")\n",
    "    print(f\"Quality Scoring: {name}\")\n",
    "    print(f\"{'='*50}\")\n",
    "    \n",
    "    X = data['X']\n",
    "    y = data['y']\n",
    "    \n",
    "    # Compute quality score\n",
    "    report = scorer.compute_dataset_quality_score(X, y, name)\n",
    "    quality_reports[name] = report\n",
    "    \n",
    "    # Show low-quality samples\n",
    "    low_quality = scorer.identify_low_quality_samples(X, y, threshold=0.4, top_k=5)\n",
    "    if not low_quality.empty:\n",
    "        print(f\"\\n  🔍 Top 5 Low-Quality Samples:\")\n",
    "        for _, row in low_quality.iterrows():\n",
    "            print(f\"    • Sample {row['sample_index']}: score={row['quality_score']:.3f}, \"\n",
    "                  f"label={row['label']}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize quality scores\n",
    "if quality_reports:\n",
    "    # Prepare data\n",
    "    quality_data = []\n",
    "    for name, report in quality_reports.items():\n",
    "        row = {\n",
    "            'Dataset': name,\n",
    "            'Overall Quality': report['overall_score'],\n",
    "            'Quality Grade': report['quality_grade']\n",
    "        }\n",
    "        row.update(report['component_scores'])\n",
    "        quality_data.append(row)\n",
    "    \n",
    "    df_quality = pd.DataFrame(quality_data)\n",
    "    \n",
    "    # Create quality dashboard\n",
    "    fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
    "    \n",
    "    # Overall quality by grade\n",
    "    grade_colors = {'EXCELLENT': 'green', 'GOOD': 'blue', 'FAIR': 'orange', 'POOR': 'red'}\n",
    "    colors = [grade_colors.get(grade, 'gray') for grade in df_quality['Quality Grade']]\n",
    "    \n",
    "    axes[0, 0].bar(df_quality['Dataset'], df_quality['Overall Quality'], color=colors)\n",
    "    axes[0, 0].set_title('Overall Quality Scores')\n",
    "    axes[0, 0].set_xlabel('Dataset')\n",
    "    axes[0, 0].set_ylabel('Quality Score')\n",
    "    axes[0, 0].tick_params(axis='x', rotation=45)\n",
    "    axes[0, 0].set_ylim(0, 1)\n",
    "    \n",
    "    # Component scores (radar chart for one dataset)\n",
    "    if len(df_quality) > 0:\n",
    "        sample_dataset = df_quality.iloc[0]\n",
    "        components = ['dataset_health', 'class_quality', 'sample_quality', 'label_confidence']\n",
    "        values = [sample_dataset[comp] for comp in components]\n",
    "        angles = np.linspace(0, 2*np.pi, len(components), endpoint=False).tolist()\n",
    "        values += values[:1]  # Close the radar chart\n",
    "        angles += angles[:1]\n",
    "        \n",
    "        ax = axes[0, 1]  # Create polar subplot\n",
    "        ax = fig.add_subplot(2, 2, 2, projection='polar')\n",
    "        ax.plot(angles, values, 'o-', linewidth=2)\n",
    "        ax.fill(angles, values, alpha=0.25)\n",
    "        ax.set_xticks(angles[:-1])\n",
    "        ax.set_xticklabels([comp.replace('_', ' ').title() for comp in components])\n",
    "        ax.set_title(f'Component Scores - {sample_dataset[\"Dataset\"]}')\n",
    "        ax.set_ylim(0, 1)\n",
    "    \n",
    "    # Component comparison across datasets\n",
    "    component_data = df_quality.melt(id_vars=['Dataset'], \n",
    "                                     value_vars=components,\n",
    "                                     var_name='Component', \n",
    "                                     value_name='Score')\n",
    "    \n",
    "    import seaborn as sns\n",
    "    sns.boxplot(x='Component', y='Score', data=component_data, ax=axes[1, 0])\n",
    "    axes[1, 0].set_title('Component Score Distribution')\n",
    "    axes[1, 0].set_xlabel('Component')\n",
    "    axes[1, 0].set_ylabel('Score')\n",
    "    axes[1, 0].tick_params(axis='x', rotation=45)\n",
    "    \n",
    "    # Weakest components\n",
    "    weakest_data = []\n",
    "    for name, report in quality_reports.items():\n",
    "        weakest = report['weakest_component']\n",
    "        weakest_data.append({\n",
    "            'Dataset': name,\n",
    "            'Weakest Component': weakest['name'].replace('_', ' ').title(),\n",
    "            'Score': weakest['score']\n",
    "        })\n",
    "    \n",
    "    df_weakest = pd.DataFrame(weakest_data)\n",
    "    pivot_data = df_weakest.pivot_table(index='Dataset', \n",
    "                                       columns='Weakest Component', \n",
    "                                       values='Score', \n",
    "                                       aggfunc='mean').fillna(0)\n",
    "    \n",
    "    pivot_data.plot(kind='bar', ax=axes[1, 1], stacked=True)\n",
    "    axes[1, 1].set_title('Weakest Components by Dataset')\n",
    "    axes[1, 1].set_xlabel('Dataset')\n",
    "    axes[1, 1].set_ylabel('Score')\n",
    "    axes[1, 1].legend(title='Weakest Component', bbox_to_anchor=(1.05, 1), loc='upper left')\n",
    "    axes[1, 1].tick_params(axis='x', rotation=45)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()"
   ]
  },
